# Banco de dados (SQLite para dev, troque para PostgreSQL/MySQL em produção)
# Dev (SQLite):
DATABASE_URL="file:./dev.db"

# Produção (PostgreSQL na Hostinger):
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/achoupro?schema=public"

# Produção (MySQL na Hostinger):
# DATABASE_URL="mysql://USER:PASS@HOST:3306/achoupro"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-valor-em-producao-rode-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Em produção: NEXTAUTH_URL="https://achoupro.com"

# Google OAuth (cadastro com Gmail) — https://console.cloud.google.com/
# GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="seu-client-secret"
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="true"

