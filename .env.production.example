# ============================================================
# AchouPro — Variáveis de Ambiente de PRODUÇÃO (Hostinger VPS)
# ============================================================
# COMO USAR:
# 1) No servidor, copie este arquivo para .env (sem o sufixo)
# 2) Substitua TODOS os valores marcados com <SUBSTITUA>
# 3) Garanta que .env NÃO seja commitado (já está no .gitignore)
# 4) Reinicie o processo PM2: pm2 restart achoupro

# ------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL no próprio VPS (recomendado)
# ------------------------------------------------------------
# Formato:
#   postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
# Exemplo local no mesmo VPS:
DATABASE_URL="postgresql://achoupro_app:<SUBSTITUA_SENHA_DO_BANCO>@localhost:5432/achoupro?schema=public"

# ------------------------------------------------------------
# NEXTAUTH — autenticação do painel admin
# ------------------------------------------------------------
# Secret gerado em 03/06/2026 — use este OU gere um novo com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="KvGEc2yMAZXrcW5Thg0WbRXfwv6Uk//ulZSGObuVfLk="

# URL pública do site (sem barra final)
NEXTAUTH_URL="https://achoupro.com.br"

# ------------------------------------------------------------
# ADMIN INICIAL (apenas para o seed; não muda nada depois)
# ------------------------------------------------------------
ADMIN_EMAIL="contato@magnocorretor.com"
# IMPORTANTE: senha forte gerada em 03/06/2026 — entregue ao cliente
# com segurança e instruções para trocar depois pelo painel
ADMIN_PASSWORD="96F09fC@ciwTzI!CF1HSLm"
ADMIN_NAME="Magno Carvalho"

# ------------------------------------------------------------
# PLATAFORMA — variáveis públicas (expostas no client)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://achoupro.com.br"
NEXT_PUBLIC_SITE_NAME="AchouPro"
NEXT_PUBLIC_WHATSAPP="5579999515563"
NEXT_PUBLIC_INSTAGRAM="https://www.instagram.com/achouprofissional"
NEXT_PUBLIC_FACEBOOK="https://www.facebook.com/share/1EMqc22Nzk/"
NEXT_PUBLIC_CONTACT_EMAIL="contato@achoupro.com.br"

# ------------------------------------------------------------
# OBSERVABILIDADE (opcional, ativar quando tiver as chaves)
# ------------------------------------------------------------
# Google Analytics 4 — pegue em https://analytics.google.com
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry (monitoramento de erros) — pegue em https://sentry.io
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Pixel do Facebook (rastreamento de conversão)
# NEXT_PUBLIC_FB_PIXEL_ID="000000000000000"

# ------------------------------------------------------------
# NODE — sempre em produção
# ------------------------------------------------------------
NODE_ENV="production"
